APP_NAME=LabConnect Inventory Service
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8003

POSTGRES_DB=labconnect
POSTGRES_USER=labconnect_user
POSTGRES_PASSWORD=labconnect_pass
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

DATABASE_URL=postgresql+psycopg2://labconnect_user:labconnect_pass@postgres:5432/labconnect

# Replace with your own strong secret outside local development.
SECRET_KEY=change_this_in_production
ALGORITHM=HS256
