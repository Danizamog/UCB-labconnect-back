# Shared reference values for local development
# Copy the service-specific files from:
# - backend/auth-service/.env.example
# - backend/inventory-service/.env.example
# - backend/reservations-service/.env.example
#
# Suggested local defaults used across the project:
POSTGRES_DB=labconnect
POSTGRES_USER=labconnect_user
POSTGRES_PASSWORD=labconnect_pass
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

REDIS_URL=redis://redis:6379/0
ALGORITHM=HS256

# Replace this with a strong secret in real deployments.
SECRET_KEY=change_this_in_production

# Public configuration that is safe to share:
ALLOWED_GOOGLE_DOMAIN=ucb.edu.bo
GOOGLE_CLIENT_ID=81257320597-3psdl1r2fbqd5dhjn4eh6tfed066p1em.apps.googleusercontent.com
